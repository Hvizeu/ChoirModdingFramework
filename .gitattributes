# Normalize public source and documentation.
* text=auto

*.java       text eol=lf
*.xml        text eol=lf
*.properties text eol=lf
*.json       text eol=lf
*.md         text eol=lf
*.txt        text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf

# LFS is reserved for confirmed-redistributable large artwork or media only.
assets/**/*.png filter=lfs diff=lfs merge=lfs -text
assets/**/*.webp filter=lfs diff=lfs merge=lfs -text
assets/**/*.ogg filter=lfs diff=lfs merge=lfs -text

*.jar binary
*.zip binary
*.exe binary
*.dll binary
